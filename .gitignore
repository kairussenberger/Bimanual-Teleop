.venv/
__pycache__/
*.pyc
.DS_Store
*.egg-info/
# TLS certs for WebXR (per-machine, never commit)
cert.pem
key.pem
*.local.yaml
# Logs / recordings
*.log
recordings/
.vr_url
*.rrd
# orbit_viz browser-viz calibration (per-machine runtime state)
config/viz_calib.json
# Generated artifacts (synthetic harness GIFs, telemetry dumps, etc.)
out/
*.gif
*.parquet
.pytest_cache/

# Unity generated project state
unity/TeleopRenderer/Library/
unity/TeleopRenderer/Temp/
unity/TeleopRenderer/Obj/
unity/TeleopRenderer/Logs/
unity/TeleopRenderer/UserSettings/
unity/TeleopRenderer/Build/
unity/TeleopRenderer/Builds/

# README media (exception to the *.gif / artifact ignores above)
!docs/media/*
# operator neutral-pose calibration (per-machine/per-operator runtime state,
# incl. timestamped .bak-* forensics copies)
config/operator_calib.json
config/operator_calib.json.*
